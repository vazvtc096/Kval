{
  "main": {
    "prefix": "main",
    "body": [
      "int main() {",
      "\t$0",
      "\treturn 0;",
      "}"
    ],
    "description": "main 函数骨架"
  },
  "class": {
    "prefix": "class",
    "body": [
      "class ${1:Name} {",
      "\t$0",
      "}"
    ],
    "description": "class 块"
  },
  "if": {
    "prefix": "if",
    "body": ["if (${1:cond}) {", "\t$0", "}"],
    "description": "if 语句"
  },
  "elif": {
    "prefix": "elif",
    "body": ["elif (${1:cond}) {", "\t$0", "}"],
    "description": "elif 分支"
  },
  "for": {
    "prefix": "for",
    "body": ["for (${1:init}; ${2:cond}; ${3:step}) {", "\t$0", "}"],
    "description": "for 循环"
  },
  "try-catch-finally": {
    "prefix": "try",
    "body": [
      "try {",
      "\t${1:// code}",
      "}",
      "catch (${2:Exception} ${3:e}) {",
      "\t${4:// handle}",
      "}",
      "finally {",
      "\t$0",
      "}"
    ],
    "description": "try-catch-finally 结构"
  },
  "throw": {
    "prefix": "throw",
    "body": ["throw ${1:error};"],
    "description": "抛出异常"
  },
  "import": {
    "prefix": "import",
    "body": ["import ${1:ModuleName}${2: as Alias};"],
    "description": "导入模块"
  },
  "from-import": {
    "prefix": "from",
    "body": ["from ${1:ModuleName} import ${2:Member}${3: as Alias};"],
    "description": "from import 导入"
  },
  "namespace": {
    "prefix": "namespace",
    "body": ["namespace ${1:Name} {", "\t$0", "}"],
    "description": "命名空间"
  },
  "class-inherit": {
    "prefix": "classi",
    "body": ["class ${1:SubClass} : ${2:public} ${3:BaseClass} {", "\t$0", "}"],
    "description": "带继承列表的 class"
  },
  "template": {
    "prefix": "template",
    "body": ["template <${1:typename T}>", "${2:void} ${3:name}(${4}) {", "\t$0", "}"],
    "description": "template 函数骨架"
  },
  "print": {
    "prefix": "print",
    "body": ["print(${1:\"\"});"],
    "description": "print 调用"
  },
  "input": {
    "prefix": "input",
    "body": ["string ${1:value} = input(${2:\"\"});"],
    "description": "input 调用"
  }
}
