#pragma once
#include "char.kval"
#include "string_ext.kval"

bool isIntLiteral(string s) {
    int idx = 0;
    int count = 0;
    for (string c : s) {
        if (idx == 0 && (c == "+" || c == "-")) {
            idx += 1;
            continue;
        }
        if (!isDigitChar(c)) {
            return false;
        }
        count += 1;
        idx += 1;
    }
    return count > 0;
}

bool isIdentifier(string s) {
    int idx = 0;
    for (string c : s) {
        if (idx == 0) {
            if (!isIdentifierStartChar(c)) {
                return false;
            }
        } else {
            if (!isIdentifierChar(c)) {
                return false;
            }
        }
        idx += 1;
    }
    return idx > 0;
}

bool isBlank(string s) {
    for (string c : s) {
        if (!isSpaceChar(c)) {
            return false;
        }
    }
    return true;
}
