#pragma once

int arrayLenInt(array a) {
    int n = 0;
    for (int v : a) {
        n += 1;
    }
    return n;
}

int arraySumInt(array a) {
    int s = 0;
    for (int v : a) {
        s += v;
    }
    return s;
}

int arrayMinInt(array a) {
    int first = 1;
    int m = 0;
    for (int v : a) {
        if (first == 1) {
            m = v;
            first = 0;
        } elif (v < m) {
            m = v;
        }
    }
    return m;
}

int arrayMaxInt(array a) {
    int first = 1;
    int m = 0;
    for (int v : a) {
        if (first == 1) {
            m = v;
            first = 0;
        } elif (v > m) {
            m = v;
        }
    }
    return m;
}

bool arrayContainsInt(array a, int x) {
    for (int v : a) {
        if (v == x) {
            return true;
        }
    }
    return false;
}

int arrayCountInt(array a, int x) {
    int c = 0;
    for (int v : a) {
        if (v == x) {
            c += 1;
        }
    }
    return c;
}

int arrayFirstIndexInt(array a, int x) {
    int i = 0;
    for (int v : a) {
        if (v == x) {
            return i;
        }
        i += 1;
    }
    return -1;
}
