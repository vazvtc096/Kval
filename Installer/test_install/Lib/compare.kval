#pragma once

int cmpInt(int a, int b) {
    if (a < b) {
        return -1;
    }
    if (a > b) {
        return 1;
    }
    return 0;
}

int cmpString(string a, string b) {
    if (a < b) {
        return -1;
    }
    if (a > b) {
        return 1;
    }
    return 0;
}

bool inRangeInclusive(int x, int lo, int hi) {
    return x >= lo && x <= hi;
}

bool inRangeExclusive(int x, int lo, int hi) {
    return x > lo && x < hi;
}

int chooseBySign(int x, int whenNeg, int whenZero, int whenPos) {
    if (x < 0) {
        return whenNeg;
    }
    if (x > 0) {
        return whenPos;
    }
    return whenZero;
}
