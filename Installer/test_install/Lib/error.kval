#pragma once
#include "typecast.kval"

const int ERR_OK = 0;
const int ERR_INVALID_ARG = 1;
const int ERR_OUT_OF_RANGE = 2;
const int ERR_PARSE = 3;
const int ERR_NOT_FOUND = 4;
const int ERR_INTERNAL = 100;

bool isOk(int err) {
    return err == ERR_OK;
}

string errorName(int err) {
    if (err == ERR_OK) {
        return "ERR_OK";
    } elif (err == ERR_INVALID_ARG) {
        return "ERR_INVALID_ARG";
    } elif (err == ERR_OUT_OF_RANGE) {
        return "ERR_OUT_OF_RANGE";
    } elif (err == ERR_PARSE) {
        return "ERR_PARSE";
    } elif (err == ERR_NOT_FOUND) {
        return "ERR_NOT_FOUND";
    } elif (err == ERR_INTERNAL) {
        return "ERR_INTERNAL";
    }
    return "ERR_UNKNOWN(" + intToString(err) + ")";
}

int require(bool cond, int errCode) {
    if (cond) {
        return ERR_OK;
    }
    return errCode;
}
