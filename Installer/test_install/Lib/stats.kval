#pragma once
#include "math.kval"
#include "numeric.kval"

int sum2(int a, int b) {
    return a + b;
}

int sum3(int a, int b, int c) {
    return a + b + c;
}

int mean2(int a, int b) {
    return average2(a, b);
}

int mean3(int a, int b, int c) {
    return average3(a, b, c);
}

int range2(int a, int b) {
    return abs(a - b);
}

int median3(int a, int b, int c) {
    if (a > b) {
        int t = a;
        a = b;
        b = t;
    }
    if (b > c) {
        int t2 = b;
        b = c;
        c = t2;
    }
    if (a > b) {
        int t3 = a;
        a = b;
        b = t3;
    }
    return b;
}

int manhattan2D(int x1, int y1, int x2, int y2) {
    return abs(x1 - x2) + abs(y1 - y2);
}
