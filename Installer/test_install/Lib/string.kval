#pragma once
#include "typecast.kval"

auto toInt = stringToInt;
auto fromInt = intToString;

string repeat(string s, int n) {
    if (n <= 0) {
        return "";
    }
    string out = "";
    while (n > 0) {
        out += s;
        n -= 1;
    }
    return out;
}

string reverse(string s) {
    string out = "";
    for (string c : s) {
        out = c + out;
    }
    return out;
}

bool startsWithChar(string s, string ch) {
    for (string c : s) {
        return c == ch;
    }
    return false;
}

bool endsWithChar(string s, string ch) {
    string last = "";
    for (string c : s) {
        last = c;
    }
    if (last == "") {
        return false;
    }
    return last == ch;
}

int countChar(string s, string ch) {
    int cnt = 0;
    for (string c : s) {
        if (c == ch) {
            cnt += 1;
        }
    }
    return cnt;
}

string padLeftChar(string s, int width, string ch) {
    int len = 0;
    for (string c : s) {
        len += 1;
    }
    if (len >= width) {
        return s;
    }
    return repeat(ch, width - len) + s;
}

string padRightChar(string s, int width, string ch) {
    int len = 0;
    for (string c : s) {
        len += 1;
    }
    if (len >= width) {
        return s;
    }
    return s + repeat(ch, width - len);
}