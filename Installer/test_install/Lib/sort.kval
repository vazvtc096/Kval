#pragma once
#include "array.kval"

bool isSortedAscInt(array a) {
    int first = 1;
    int prev = 0;
    for (int v : a) {
        if (first == 1) {
            prev = v;
            first = 0;
            continue;
        }
        if (prev > v) {
            return false;
        }
        prev = v;
    }
    return true;
}

bool isSortedDescInt(array a) {
    int first = 1;
    int prev = 0;
    for (int v : a) {
        if (first == 1) {
            prev = v;
            first = 0;
            continue;
        }
        if (prev < v) {
            return false;
        }
        prev = v;
    }
    return true;
}
