#pragma once
from py_std_math import bit_and as __py_bit_and, bit_or as __py_bit_or, bit_xor as __py_bit_xor, bit_not as __py_bit_not, shl as __py_shl, shr as __py_shr;

int shl(int a, int n) {
    return __py_shl(a, n);
}

int shr(int a, int n) {
    return __py_shr(a, n);
}

bool hasBit(int value, int bitIndex) {
    return bitAnd(shr(value, bitIndex), 1) == 1;
}

int setBit(int value, int bitIndex) {
    return bitOr(value, shl(1, bitIndex));
}

int clearBit(int value, int bitIndex) {
    return bitAnd(value, bitNot(shl(1, bitIndex)));
}

int toggleBit(int value, int bitIndex) {
    return bitXor(value, shl(1, bitIndex));
}

int bitAnd(int a, int b) {
    return __py_bit_and(a, b);
}

int bitOr(int a, int b) {
    return __py_bit_or(a, b);
}

int bitXor(int a, int b) {
    return __py_bit_xor(a, b);
}

int bitNot(int a) {
    return __py_bit_not(a);
}
