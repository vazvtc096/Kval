#pragma once
#include "random.kval"
#include "typecast.kval"

string __hexDigit(int n) {
    switch (n) {
        case (0) { return "0"; }
        case (1) { return "1"; }
        case (2) { return "2"; }
        case (3) { return "3"; }
        case (4) { return "4"; }
        case (5) { return "5"; }
        case (6) { return "6"; }
        case (7) { return "7"; }
        case (8) { return "8"; }
        case (9) { return "9"; }
        case (10) { return "a"; }
        case (11) { return "b"; }
        case (12) { return "c"; }
        case (13) { return "d"; }
        case (14) { return "e"; }
        case (15) { return "f"; }
    }
    return "0";
}

string randomHex(int n) {
    if (n <= 0) {
        return "";
    }
    string out = "";
    while (n > 0) {
        int v = randRange(0, 15);
        out += __hexDigit(v);
        n -= 1;
    }
    return out;
}

string uuidLike() {
    string p1 = randomHex(8);
    string p2 = randomHex(4);
    string p3 = randomHex(4);
    string p4 = randomHex(4);
    string p5 = randomHex(12);
    return p1 + "-" + p2 + "-" + p3 + "-" + p4 + "-" + p5;
}

string shortId() {
    return randomHex(12);
}
